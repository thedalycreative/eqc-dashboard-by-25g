rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{doc} {
      allow read, write: if true;
    }
    match /events/{doc} {
      allow read, write: if true;
    }
    match /staff/{doc} {
      allow read, write: if true;
    }
    match /announcements/{doc} {
      allow read, write: if true;
    }
    match /config/{doc} {
      allow read, write: if true;
    }
  }
}
